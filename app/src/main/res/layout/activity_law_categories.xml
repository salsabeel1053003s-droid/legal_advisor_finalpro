<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:layoutDirection="ltr"> <com.google.android.material.appbar.MaterialToolbar
    android:id="@+id/toolbar_categories"
    android:layout_width="match_parent"
    android:layout_height="?attr/actionBarSize"
    android:background="@color/surface_dark"
    app:title="Legal Categories"
    app:titleTextColor="@color/white"
    app:navigationIcon="@drawable/baseline_arrow_back_24"
    app:navigationIconTint="@color/gold"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_categories"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar_categories"

        android:padding="8dp"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="16dp"
        android:src="@drawable/baseline_add_24"
        app:backgroundTint="@color/gold"
        app:tint="@color/primary_dark" />

</RelativeLayout>
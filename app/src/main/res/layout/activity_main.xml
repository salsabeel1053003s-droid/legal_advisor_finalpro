<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <!-- خلفية شفافه -->
    <ImageView
        android:id="@+id/background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/login_background"
        android:scaleType="centerCrop"
        android:alpha="0.2"
        android:contentDescription="@null" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black_overlay"
        android:alpha="0.5" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- العنوان والقائمة -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="@string/header_title"
                    android:textColor="@color/neon_blue"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2" />

                <ImageButton
                    android:id="@+id/btnMenu"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/neon_card_bg"
                    android:src="@android:drawable/ic_menu_more"
                    app:tint="@color/neon_blue" />
            </RelativeLayout>

            <!-- الترحيب والتاريخ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="@string/welcome_back"
                android:textColor="@color/text_gray"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/user_name"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_gray"
                android:layout_marginBottom="30dp"
                android:text="@string/loading_date" />

            <!-- كروت الشبكة -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- AI Advisor -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAI"
                    android:layout_width="match_parent"
                    android:layout_height="85dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/iconAI"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            app:cardBackgroundColor="@color/neon_blue"
                            app:cardCornerRadius="14dp">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/stat_notify_chat"
                                app:tint="@color/white" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toEndOf="@id/iconAI"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AI Advisor"
                                android:textColor="@color/neon_blue"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Smart legal assistance"
                                android:textColor="#88FFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Human Advisor -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardHuman"
                    android:layout_width="match_parent"
                    android:layout_height="85dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/iconHuman"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            app:cardBackgroundColor="@color/neon_blue"
                            app:cardCornerRadius="14dp">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_myplaces"
                                app:tint="@color/white" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toEndOf="@id/iconHuman"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Human Advisor"
                                android:textColor="@color/neon_blue"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Connect with professionals"
                                android:textColor="#88FFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Laws -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardLaws"
                    android:layout_width="match_parent"
                    android:layout_height="85dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/iconLaws"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            app:cardBackgroundColor="#FFD700"
                            app:cardCornerRadius="28dp">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_agenda" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toEndOf="@id/iconLaws"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Laws"
                                android:textColor="#FFD700"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Browse laws , articles"
                                android:textColor="#88FFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Consultations -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardConsult"
                    android:layout_width="match_parent"
                    android:layout_height="85dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/iconConsult"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            app:cardBackgroundColor="@color/neon_blue"
                            app:cardCornerRadius="14dp">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_help"
                                app:tint="@color/white" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toEndOf="@id/iconConsult"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Consultations"
                                android:textColor="@color/neon_blue"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="View your history"
                                android:textColor="#88FFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Contact Us -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardContact"
                    android:layout_width="match_parent"
                    android:layout_height="85dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/iconContact"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            app:cardBackgroundColor="@color/neon_blue"
                            app:cardCornerRadius="14dp">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_call"
                                app:tint="@color/white" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toEndOf="@id/iconContact"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Contact Us"
                                android:textColor="@color/neon_blue"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Get support anytime"
                                android:textColor="#88FFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- قائمة جانبية للتعتيم -->
    <View
        android:id="@+id/menuOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:visibility="gone" />

    <androidx.cardview.widget.CardView
        android:id="@+id/menuContainer"
        android:layout_width="250dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:visibility="gone"
        app:cardBackgroundColor="#1C1C1C"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp">

        <!-- عناصر القائمة الجانبية يمكن إضافتها هنا -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/menuFavoritesItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Favorites"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:padding="8dp" />

            <TextView
                android:id="@+id/menuNotificationsItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notifications"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:padding="8dp" />

            <TextView
                android:id="@+id/menuSettingsItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:padding="8dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>
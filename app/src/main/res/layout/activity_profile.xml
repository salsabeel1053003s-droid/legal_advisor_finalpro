<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <!-- ═══ Background Image ═══ -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/login_background"
        android:scaleType="centerCrop"
        android:alpha="0.18"
        android:contentDescription="@null" />

    <!-- ═══ Dark Overlay ═══ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black_overlay" />

    <!-- ═══ Toolbar ═══ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentTop="true"
        app:cardBackgroundColor="#CC0a1628"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/neon_card_bg"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="@string/back"
                android:padding="8dp"
                app:tint="@color/neon_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Profile"
                android:textColor="@color/neon_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <ImageButton
                android:id="@+id/btnNotifications"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/neon_card_bg"
                android:src="@android:drawable/ic_popup_reminder"
                android:contentDescription="Notifications"
                android:padding="8dp"
                app:tint="@color/text_gray" />

        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- خط نيون تحت التولبار -->
    <View
        android:id="@+id/divToolbar"
        android:layout_width="match_parent"
        android:layout_height="1.5dp"
        android:layout_below="@id/toolbar"
        android:background="@color/neon_blue"
        android:alpha="0.5" />

    <!-- ═══ المحتوى ═══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/divToolbar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="32dp">

            <!-- ═══ Profile Card ═══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/neon_card_bg"
                    android:padding="20dp">

                    <!-- Avatar -->
                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/circle_shape"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:padding="14dp"
                        android:contentDescription="@null"
                        app:tint="@color/neon_blue" />

                    <!-- Info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Anas Al-Ahmad"
                            android:textColor="@color/white"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvUserEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="anas@example.com"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp"
                            android:layout_marginTop="3dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Premium Member"
                            android:textColor="@color/neon_blue"
                            android:textSize="10sp"
                            android:background="@drawable/neon_card_bg"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                    <!-- Edit Button -->
                    <ImageButton
                        android:id="@+id/btnEditProfile"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/neon_card_bg"
                        android:src="@android:drawable/ic_menu_edit"
                        android:contentDescription="Edit"
                        android:padding="8dp"
                        app:tint="@color/neon_blue" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section: ACCOUNT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCOUNT"
                android:textColor="@color/text_gray"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <!-- Change Password -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnChangePassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/neon_card_bg"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/circle_shape"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        android:padding="8dp"
                        android:contentDescription="@null"
                        app:tint="@color/neon_blue" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Change Password"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Keep your account secure"
                            android:textColor="@color/text_gray"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/text_gray"
                        android:textSize="22sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section: OTHER -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OTHER"
                android:textColor="@color/text_gray"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <!-- Logout -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/neon_card_bg"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/circle_shape"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:padding="8dp"
                        android:contentDescription="@null"
                        app:tint="#FF5050" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Logout"
                            android:textColor="#FF5050"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign out of your account"
                            android:textColor="@color/text_gray"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#FF5050"
                        android:textSize="22sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RegistrationActivity">

    <ImageView
        android:id="@+id/background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/login_background"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black_overlay" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_title"
                android:textColor="@color/neon_blue"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_subtitle"
                android:textColor="@color/text_gray"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:gravity="center" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="20dp"
                app:cardElevation="15dp"
                app:cardMaxElevation="20dp"
                app:cardUseCompatPadding="true"
                android:outlineAmbientShadowColor="@color/neon_blue"
                android:outlineSpotShadowColor="@color/neon_blue">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_neon_border"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <EditText
                        android:id="@+id/etRegUsername"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/edit_text_rounded"
                        android:hint="@string/hint_username"
                        android:textColorHint="@color/text_gray"
                        android:textColor="@color/white"
                        android:paddingStart="15dp"
                        android:inputType="textPersonName"
                        android:drawableStart="@android:drawable/ic_menu_myplaces"
                        android:drawablePadding="10dp"
                        android:paddingEnd="15dp" />

                    <EditText
                        android:id="@+id/etRegEmail"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/edit_text_rounded"
                        android:hint="@string/hint_email"
                        android:textColorHint="@color/text_gray"
                        android:textColor="@color/white"
                        android:paddingStart="15dp"
                        android:inputType="textEmailAddress"
                        android:drawableStart="@android:drawable/ic_dialog_email"
                        android:drawablePadding="10dp"
                        android:paddingEnd="15dp" />

                    <EditText
                        android:id="@+id/etRegPassword"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/edit_text_rounded"
                        android:hint="@string/hint_password"
                        android:textColorHint="@color/text_gray"
                        android:textColor="@color/white"
                        android:inputType="textPassword"
                        android:paddingStart="15dp"
                        android:paddingEnd="15dp"
                        android:drawableStart="@android:drawable/ic_lock_idle_lock"
                        android:drawablePadding="10dp" />

                    <EditText
                        android:id="@+id/etRegConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/edit_text_rounded"
                        android:hint="@string/hint_confirm_password"
                        android:textColorHint="@color/text_gray"
                        android:textColor="@color/white"
                        android:inputType="textPassword"
                        android:autofillHints="password"
                        android:paddingStart="15dp"
                        android:paddingEnd="15dp"
                        android:drawableStart="@android:drawable/ic_lock_idle_lock"
                        android:drawablePadding="10dp" />

                    <Button
                        android:id="@+id/btnSignUp"
                        android:layout_width="180dp"
                        android:layout_height="50dp"
                        android:layout_marginTop="25dp"
                        android:layout_gravity="center"
                        android:text="@string/btn_register"
                        android:backgroundTint="@color/neon_blue"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textAllCaps="false" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/already_have_account"
                android:textColor="@color/neon_blue"
                android:textStyle="bold"
                android:textSize="14sp"
                android:paddingBottom="20dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:padding="16dp">

    <TextView
        android:id="@+id/aiTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI Legal Advisor"
        android:textColor="@color/neon_blue"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/inputArea"
        android:layout_below="@id/aiTitle"
        android:layout_marginVertical="20dp"
        app:cardBackgroundColor="#121520"
        app:cardCornerRadius="15dp"
        app:cardElevation="0dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How can I help you legally today?"
            android:textColor="@color/text_gray"
            android:layout_gravity="center"
            android:textSize="14sp"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/inputArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="@drawable/card_neon_border"
        android:padding="8dp">

        <EditText
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Write your inquiry here..."
            android:textColor="@color/white"
            android:textColorHint="@color/text_gray"
            android:background="@android:color/transparent"
            android:padding="10dp"/>

        <ImageButton
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@android:drawable/ic_menu_send"
            app:tint="@color/neon_blue"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>
</RelativeLayout>